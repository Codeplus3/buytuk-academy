# BuyTuk Academy Environment Configuration
# Copy this file to .env and update values accordingly

# Application
VITE_APP_NAME=BuyTuk Academy
VITE_APP_DESCRIPTION=A smart integrated educational platform

# API Configuration
VITE_API_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000

# Features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true

# Languages
VITE_DEFAULT_LANGUAGE=ar
VITE_SUPPORTED_LANGUAGES=ar,en

# Service Worker
VITE_SW_ENABLED=true

# Build
VITE_SOURCE_MAP=false
